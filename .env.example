# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/hotspot-portal

# JWT Secret (change this to a long random string)
JWT_SECRET=your_super_secret_jwt_key_change_this

# M-Pesa Daraja API Credentials
MPESA_CONSUMER_KEY=your_consumer_key_from_daraja
MPESA_CONSUMER_SECRET=your_consumer_secret_from_daraja
MPESA_PASSKEY=your_lipa_na_mpesa_passkey
MPESA_SHORTCODE=174379
MPESA_ENV=sandbox

# Callback URL (your public URL after deployment)
MPESA_CALLBACK_URL=https://your-app.onrender.com/api/payment/mpesa/callback

# Admin Credentials
ADMIN_EMAIL=admin@hotspot.com
ADMIN_PASSWORD=Admin@1234
